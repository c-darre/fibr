<div class="container py-5"
     style="max-width: 700px;"
     data-controller="discussion-polling"
     data-discussion-polling-waiting-value="<%= @messages.last&.role == 'user' %>">

  <div class="d-flex align-items-center mb-4">
    <%= link_to analysis_path(@analysis), class: "text-dark me-3" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
    <h4 class="mb-0 fw-bold text-uppercase" style="font-family: 'Albert Sans', sans-serif;">Expert Discussion</h4>
  </div>

  <div class="d-flex flex-column gap-3 mb-4">
    <% @messages.each do |message| %>
      <% if message.role == "user" %>
        <div class="align-self-end" style="max-width: 75%;">
          <div class="p-3 text-white" style="background-color: #000; font-family: 'Albert Sans', sans-serif;">
            <%= message.content %>
          </div>
        </div>
      <% else %>
        <div class="align-self-start" style="max-width: 75%;">
          <div class="p-3 border border-dark border-2" style="background-color: white; font-family: 'Albert Sans', sans-serif;">
            <%= message.content %>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if @messages.last&.role == "user" %>
      <div class="align-self-start text-muted small fst-italic">Expert is typing…</div>
    <% end %>
  </div>

  <%= form_with model: @message, url: analysis_chat_messages_path(@analysis, @chat) do |f| %>
    <div class="d-flex gap-2 align-items-end">
      <%= f.text_area :content,
            placeholder: "Ask a question about your analysis…",
            class: "form-control border-dark border-2",
            rows: 2,
            style: "border-radius: 0; font-family: 'Albert Sans', sans-serif;" %>
      <%= f.submit "Send", class: "btn btn_fibr" %>
    </div>
  <% end %>

</div>
