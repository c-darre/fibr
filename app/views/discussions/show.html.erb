<%= turbo_stream_from "chat_#{@chat.id}" %>

<div class="quiz-page d-flex flex-column">

  <div class="quiz-header">
    <div class="d-flex align-items-center">
      <%= link_to analysis_path(@analysis), class: "chat-back me-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
      <% end %>
    </div>
    <h1 class="quiz-title mb-0" style="margin-top: -30px;"><br>Expert discussion</h1>
  </div>

  <%# ── C'est ici que la magie opère en inline style ── %>
  <div id="messages-container"
       class="quiz-messages flex-grow-1"
       style="background-image: url('<%= asset_path("chat_bg.svg") %>'); background-repeat: no-repeat; background-position: center; background-size: 150px; padding: 1rem;">
    <%= render @messages %>
  </div>

  <div class="quiz-input-bar">
    <%= form_with model: @message, url: analysis_chat_messages_path(@analysis, @chat) do |f| %>
      <div class="quiz-input-row">
        <%# ── Ajout de l'événement onkeydown juste ici 👇 ── %>
        <%= f.text_area :content,
              placeholder: "Ask your question…",
              class: "quiz-text-input",
              rows: 1,
              onkeydown: "if(event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); this.form.requestSubmit(); }" %>

        <button type="submit" class="quiz-send" aria-label="Send">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.27 3.27 21 12 3.27 20.73 6 12Zm0 0h6"/></svg>
        </button>
      </div>
    <% end %>
  </div>
</div>

<script>
  // Scroll auto en bas à chaque nouveau message (au chargement + à chaque ajout Turbo Stream)
  function scrollChatEnBas() {
    const c = document.getElementById("messages-container")
    if (c) c.scrollTop = c.scrollHeight
  }
  document.addEventListener("turbo:load", scrollChatEnBas)
  // Quand Turbo Stream ajoute un message, on re-scroll
  document.addEventListener("turbo:before-stream-render", function () {
    setTimeout(scrollChatEnBas, 50)
  })
  // Vide le champ après envoi (puisqu'on ne recharge plus la page)
  document.addEventListener("turbo:submit-end", function () {
    const champ = document.querySelector(".quiz-text-input")
    if (champ) champ.value = ""
  })
</script>
