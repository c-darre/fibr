<%# _navbar.html.erb %>

<nav class="navbar bg-white">
  <div class="container d-flex align-items-center justify-content-between">

    <button class="navbar-toggler border-0 px-0"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#mobileMenu">
      <i class="fa-solid fa-bars custom-burger-icon" style="color: #000000 !important;"></i>
    </button>

    <%= link_to root_path, class: "navbar-brand mb-0" do %>
      <%= image_tag "Logo_black.svg", alt: "FIB__R Logo", style: "height: 12px; width: auto;" %>
    <% end %>
  </div>
</nav>

<div class="offcanvas bg-white offcanvas-start"
     tabindex="-1"
     id="mobileMenu">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title mb-0">
      <%= image_tag "Logo_black.svg", alt: "FIB__R Logo", style: "height: 12px; width: auto;" %>
    </h5>
    <button type="button"
            class="btn-close"
            data-bs-dismiss="offcanvas">
    </button>
  </div>

  <div class="offcanvas-body d-flex flex-column" style="background-color:#f9e9d9;">
    <div class="d-grid gap-2">
      <%= button_to analyses_path,
        method: :post,
        class: "btn go-btn text-start fw-semibold" do %>
        + New analysis
      <% end %>
      <%= link_to "History",
        analyses_path,
        class: "btn history-btn text-center fw-semibold",
        style: "width: 33%; background-color: #fff; border-radius: 50px;" %>
    </div>
    <hr>

    <% if user_signed_in? %>
      <%# Query updated to only show completed records matching your clean history look %>
      <% recent_analyses = current_user.analyses
          .where(status: 'completed')
          .order(created_at: :desc)
          .limit(3) %>

      <% if recent_analyses.any? %>
        <div class="mt-4">
          <p class="text-uppercase text-muted fw-bold small mb-3">
            Recent
          </p>
          <div class="d-flex flex-column gap-2">
            <% recent_analyses.each do |analysis| %>
              <% photo = analysis.analysis_chat&.messages&.first&.photos&.second %>

              <%= link_to analysis_path(analysis), class: "text-decoration-none d-flex justify-content-between align-items-center border rounded-4 bg-white mb-2 p-0 pe-2 shadow-sm text-dark overflow-hidden" do %>

                <%# Left Side: Thumbnail and Title %>
                <div class="d-flex align-items-center gap-3 text-truncate">
                  <% if photo %>
                    <%= image_tag photo, class: "chat-thumbnail", style: "width: 70px; height: 70px; object-fit: cover;" %>
                  <% else %>
                    <div class="chat-thumbnail placeholder-emoji d-flex align-items-center justify-content-center border-end text-muted bg-light"
                         style="width: 70px; height: 70px; font-size: 24px;">
                      👖
                    </div>
                  <% end %>

                  <div class="text-truncate py-2">
                    <h6 class="mb-0 fw-bold text-dark text-truncate small" style="font-size: 14px;">
                      <%= analysis.garment_type.presence || "Analysis of #{analysis.created_at.strftime('%d/%m/%Y')}" %>
                    </h6>
                    <small class="text-muted text-lowercase" style="font-size: 11px;"><%= analysis.status %></small>
                  </div>
                </div>

                <%# Right Side: Mini Score Ring / Fallback Dash %>
                <div class="ms-2 me-1">
                  <%
                    total_score   = analysis.criteria.sum(:score)
                    max_score     = analysis.criteria.count * 10
                    average_score = max_score > 0 ? (total_score.to_f / max_score * 10).ceil(1) : nil
                  %>

                  <% if average_score %>
                    <% if average_score < 4 %>
                      <% couleur = "#dc3545" %>
                    <% elsif average_score < 7 %>
                      <% couleur = "#ffc107" %>
                    <% else %>
                      <% couleur = "#198754" %>
                    <% end %>

                    <%
                      score_percentage = (average_score * 10).to_i
                      # CALCULATION FOR 60x60px RING: Radius 22, Circumference = 2 * PI * 22 = 138.23
                      navbar_circumference = 138.23
                      navbar_stroke_offset = navbar_circumference - ((score_percentage / 100.0) * navbar_circumference)
                    %>

                    <%# UPDATED: Raised wrapper dimensions to 60px %>
                    <div class="score-circle position-relative d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                      <svg class="progress-ring" width="60" height="60" style="transform: rotate(-90deg); overflow: visible;">
                        <circle class="progress-ring-track" cx="30" cy="30" r="22" stroke="#e9ecef" stroke-width="2.5" fill="transparent" />
                        <circle class="progress-ring-fill"
                                cx="30"
                                cy="30"
                                r="22"
                                stroke="<%= couleur %>"
                                stroke-width="2.5"
                                fill="transparent"
                                stroke-dasharray="<%= navbar_circumference %>"
                                style="stroke-dashoffset: <%= navbar_stroke_offset %>px;" />
                      </svg>
                      <%# UPDATED: Linked directly to the history inner text class & explicitly defined identical font configurations %>
                      <div class="progress-inner-text position-absolute fw-bold text-dark"
                           style="font-size: 14px; font-weight: 700 !important; line-height: 1; letter-spacing: -0.2px;">
                        <%= average_score %>
                      </div>
                    </div>
                  <% else %>
                    <%# UPDATED: Balanced hyphen alignment block dimensions to 60px %>
                    <div class="d-flex align-items-center justify-content-center text-muted me-2" style="width: 60px; height: 60px; font-size: 16px; font-weight: 700;">
                      -
                    </div>
                  <% end %>
                </div>

              <% end %> <%# Ends link_to link path %>
            <% end %> <%# Ends recent_analyses.each loop %>
          </div>
        </div>
      <% end %> <%# Ends recent_analyses.any? check %>

      <div class="mt-auto">
        <p class="text-muted small mb-2">
          <%= current_user.email %>
        </p>
        <%= link_to "Sign out",
          destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "btn go-btn w-100 fw-semibold" %>
      </div>

    <% else %> <%# Main user_signed_in? Fallback %>
      <div class="mt-auto d-grid gap-2">
        <%= link_to "Sign in",
          new_user_session_path,
          class: "btn go-btn fw-semibold" %>
        <%= link_to "Sign up",
          new_user_registration_path,
          class: "btn history-btn fw-semibold" %>
      </div>
    <% end %> <%# Ends main user_signed_in? check %>
  </div>
</div>
