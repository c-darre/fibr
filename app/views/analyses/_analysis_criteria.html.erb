<div id="analysis_criteria">
  <% if analysis.pending? || analysis.processing? %>
    <h5 class="mb-3 placeholder-glow">
      <span class="placeholder col-4 rounded"></span>
    </h5>
    <div class="row g-3 mb-4">
      <% 5.times do %>
        <div class="col-md-4">
          <div class="card h-100 p-3 shadow-sm">
            <p class="placeholder-glow fw-bold mb-1">
              <span class="placeholder col-6 rounded"></span>
            </p>
            <p class="placeholder-glow small flex-grow-1 mb-2">
              <span class="placeholder col-12 rounded"></span>
              <span class="placeholder col-8 rounded"></span>
            </p>
            <p class="placeholder-glow mb-0">
              <span class="placeholder col-3 rounded"></span>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% elsif analysis.completed? %>
    <h5 class="mb-3">Criteria details</h5>
    <div class="row g-3 mb-4">
      <% analysis.criteria.each do |criterion| %>
        <div class="col-md-4">
          <div class="card h-100 p-3 shadow-sm">
            <h6 class="fw-bold mb-1"><%= criterion.name %></h6>
            <p class="text-muted small flex-grow-1 mb-2"><%= criterion.detail %></p>
            <span class="badge bg-primary fs-6"><%= criterion.score %> / 10</span>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
