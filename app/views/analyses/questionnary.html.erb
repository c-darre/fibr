<%= turbo_stream_from "chat_#{@chat.id}" %>

<div class="quiz-page d-flex flex-column">

  <%# En-tête %>
  <div class="quiz-header">
    <h1 class="quiz-title">Estimate the impact</h1>
  </div>

  <%# Fil de messages %>
  <div id="messages-container" class="quiz-messages flex-grow-1">
    <%= render @chat.messages.order(:created_at) %>
  </div>

  <%# Barre de saisie OU bouton résultats (selon que l'impact est calculé) %>
  <div id="quiz-input-zone">
    <% if @analysis.co2.present? %>
      <div class="quiz-input-bar text-center">
        <p class="result-subtitle mb-2">Analysis complete ✓</p>
        <%= link_to "See your results →", analysis_path(@analysis),
              class: "btn_fibr_pill d-block text-center text-decoration-none" %>
      </div>
    <% else %>
      <div class="quiz-input-bar">
        <div class="quiz-sizes">
          <button type="button" class="quiz-size" data-size="XS">XS</button>
          <button type="button" class="quiz-size" data-size="S">S</button>
          <button type="button" class="quiz-size" data-size="M">M</button>
          <button type="button" class="quiz-size" data-size="L">L</button>
          <button type="button" class="quiz-size" data-size="XL">XL</button>
          <button type="button" class="quiz-size" data-size="XXL">XXL</button>
        </div>

        <%= form_with url: analysis_chat_messages_path(@analysis, @chat), method: :post, local: true, id: "quiz-form" do |f| %>
          <div class="quiz-input-row">
            <input type="text" name="message[content]" id="quiz-input"
                   placeholder="Your answer (e.g. size M)"
                   class="quiz-text-input" autocomplete="off">
            <button type="submit" class="quiz-send" aria-label="Send">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.27 3.27 21 12 3.27 20.73 6 12Zm0 0h6"/></svg>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.querySelectorAll(".quiz-size").forEach(function(btn) {
    btn.addEventListener("click", function() {
      document.getElementById("quiz-input").value = btn.dataset.size
      document.getElementById("quiz-form").requestSubmit()
    })
  })
</script>
