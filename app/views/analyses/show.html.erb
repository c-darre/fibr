<div class="result-page">

  <% if @analysis.pending? || @analysis.processing? %>
    <%# ── Spinner + polling (inchangé) ──────────────────── %>
    <div class="container py-5 text-center" id="processing-view" style="max-width: 700px;">
      <div class="spinner-border text-secondary mb-4" role="status" style="width: 3rem; height: 3rem;">
        <span class="visually-hidden">Analysis in progress…</span>
      </div>
      <h3 class="mb-2">Analysis in progress</h3>
      <p class="text-muted" id="loading-message">Analysing your garment…</p>
    </div>

    <script>
      // Phrases qui défilent pendant le chargement
      const messages = [
        "Analysing your garment…",
        "Reading the composition label…",
        "Evaluating stitching quality…",
        "Estimating durability…",
        "Analysing the finishing…",
        "Calculating the overall score…"
      ]
      let indexMessage = 0
      const elMessage = document.getElementById("loading-message")

      setInterval(function () {
        indexMessage = (indexMessage + 1) % messages.length
        elMessage.style.opacity = 0          // fondu sortant
        setTimeout(function () {
          elMessage.textContent = messages[indexMessage]
          elMessage.style.opacity = 1        // fondu entrant
        }, 300)
      }, 2500)   // change de phrase toutes les 2,5 s
      const pollingInterval = setInterval(function () {
        fetch('<%= analysis_path(@analysis, format: :json) %>', { headers: { 'Accept': 'application/json' } })
          .then(function (response) { return response.json(); })
          .then(function (data) {
            if (data.status !== 'processing' && data.status !== 'pending') {
              clearInterval(pollingInterval);
              window.location.reload();
            }
          })
          .catch(function () { clearInterval(pollingInterval); });
      }, 2000);
    </script>

  <% elsif @analysis.completed? %>
    <%
      total_score = @analysis.criteria.sum(:score)
      max_score   = @analysis.criteria.count * 10
      global_pct  = max_score > 0 ? (total_score.to_f / max_score * 10).ceil(1) : 0

      # Logique pour la couleur et le texte de la note
      if global_pct >= 7
        badge_text = "GOOD"
        badge_color = "#198754" # Vert (Bootstrap success)
      elsif global_pct >= 4
        badge_text = "AVERAGE"
        badge_color = "#ffc107" # Jaune (Bootstrap warning)
      else
        badge_text = "LOW"
        badge_color = "#dc3545" # Rouge (Bootstrap danger)
      end
    %>

    <%# ── En-tête ──────────────────────────────────────── %>
    <div class="result-header">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h1 class="start-text text-uppercase" style="margin: 0px; font-size: 24px; margin-bottom: -22px;">Analysis results</h1>
        </div>
        <% if @analysis.garment_type.present? %>
          <span class="result-tag"><%= @analysis.garment_type %><%= " · #{@analysis.garment_size}" if @analysis.garment_size.present? %></span>
        <% end %>
      </div>
    </div>

    <%# ── Cercle orbital ───────────────────────────────── %>
    <div class="d-flex justify-content-center w-100">
      <div class="orbital" id="orbital" style="margin-top: -22px;">
        <%# Le score au centre %>
        <div class="orbital-center" id="orbital-center">
          <div class="orbital-score"><%= global_pct %><span class="orbital-score-max">/10</span></div>
          <div class="orbital-badge" style="color: <%= badge_color %>;">
            <span class="orbital-badge-dot" style="background-color: <%= badge_color %>;"></span>
            <%= badge_text %>
          </div>
        </div>

        <%# Les critères en orbite (générés depuis la base) %>
        <% @analysis.criteria.each_with_index do |criterion, i| %>
          <%
            # Calcul de la couleur spécifique à ce critère
            crit_score = criterion.score.to_f
            if crit_score >= 7
              crit_color = "#198754" # Vert
            elsif crit_score >= 4
              crit_color = "#ffc107" # Jaune/Orange
            else
              crit_color = "#dc3545" # Rouge
            end
          %>
          <div class="orbital-node"
               data-index="<%= i %>"
               data-name="<%= criterion.name %>"
               data-score="<%= criterion.score %>"
               data-detail="<%= criterion.detail %>"
               data-color="<%= crit_color %>">
            <div class="orbital-node-circle">
              <span class="orbital-node-score"><%= criterion.score %></span>
            </div>
            <div class="orbital-node-label"><%= criterion.name %></div>
          </div>
        <% end %>

        <%# Carte de détail (cachée, s'affiche au clic) %>
        <div class="orbital-detail" id="orbital-detail">
          <div class="orbital-detail-head">
            <span class="orbital-detail-badge" id="detail-score">–</span>
            <button type="button" class="orbital-detail-close" id="detail-close">✕</button>
          </div>
          <h3 class="orbital-detail-title" id="detail-name">–</h3>
          <p class="orbital-detail-text" id="detail-text">–</p>
        </div>
      </div>
    </div>

    <%# ── Carte "Aller plus loin" / impact ─────────────── %>
    <div class="result-bottom">
      <% if @analysis.co2.present? %>
        <div class="impact-card">
          <p class="result-step">ENVIRONMENTAL IMPACT</p>
          <div class="impact-row"><span>CO₂</span><strong><%= @analysis.co2.round(2) %> kg</strong></div>
          <div class="impact-row"><span>Water</span><strong><%= @analysis.water.round(2) %></strong></div>
          <div class="impact-row"><span>Impact score - the less the best</span><strong><%= @analysis.global_score.round(0) %></strong></div>
          <p class="result-subtitle mt-2">Estimate based on size <%= @analysis.garment_size %>.</p>
          <div class="d-flex justify-content-center mt-3">
            <%= link_to "ASK A QUESTION →", analysis_discussion_path(@analysis), class: "go-btn bg-dark text-white px-5 py-2 border-0 text-uppercase text-decoration-none" %>
          </div>
        </div>
      <% else %>
        <div class="impact-card">
          <p class="result-step">⬡ OPTIONAL</p>
          <h3 class="start-text" style="margin-top: 2px; font-size: 14px;">ESTIMATE ENVIRONMENTAL IMPACT</h3>
          <p class="result-subtitle">A few questions are enough to estimate the carbon and water footprint of this item.</p>
          <div class="d-flex justify-content-center mt-3">
            <%= button_to "GO FURTHER", start_questionnary_analysis_path(@analysis), method: :post, class: "go-btn bg-dark text-white px-5 py-2 border-0 text-uppercase" %>
          </div>
        </div>
      <% end %>

      <div class="text-center mt-3">
        <%= button_to "↻ NEW ANALYSIS", analyses_path, method: :post, class: "result-new-btn text-uppercase" %>
      </div>
    </div>

  <% elsif @analysis.failed? %>
    <div class="container py-5" style="max-width: 700px;">
      <div class="alert alert-danger">
        <h4 class="alert-heading">Analysis failed</h4>
        <p class="mb-3">An error occurred during processing. Please try again.</p>
        <%= button_to "TRY AGAIN", analyses_path, method: :post, class: "btn btn-outline-danger text-uppercase" %>
      </div>
    </div>
  <% end %>

</div>

<script>
  document.addEventListener("turbo:load", function () {
    const orbital = document.getElementById("orbital")
    if (!orbital) return
    if (orbital.dataset.initialized === "true") return
    orbital.dataset.initialized = "true"

    const noeuds = Array.from(document.querySelectorAll(".orbital-node"))
    const total = noeuds.length
    const rayon = 145
    let angle = 0
    let enRotation = true
    let noeudActif = null

    const detail = document.getElementById("orbital-detail")

    function placerNoeuds() {
      noeuds.forEach(function (noeud, i) {
        const a = ((i / total) * 360 + angle) * Math.PI / 180
        const x = Math.cos(a) * rayon
        const y = Math.sin(a) * rayon
        noeud.style.transform = "translate(" + x + "px, " + y + "px)"
      })
    }

    function animer() {
      if (enRotation) {
        angle = (angle + 0.075) % 360
        placerNoeuds()
      }
      requestAnimationFrame(animer)
    }

    function ouvrirDetail(noeud) {
      document.getElementById("detail-name").textContent  = noeud.dataset.name

      const badge = document.getElementById("detail-score")
      badge.textContent = noeud.dataset.score + " / 10"

      // Application de la couleur dynamique à la note (badge)
      badge.style.backgroundColor = noeud.dataset.color
      badge.style.borderColor = noeud.dataset.color
      badge.style.color = "#ffffff" // Force le texte en blanc pour le contraste

      document.getElementById("detail-text").textContent  = noeud.dataset.detail
      detail.classList.add("is-open")
    }

    noeuds.forEach(function (noeud) {
      noeud.addEventListener("click", function () {
        if (noeudActif) {
          noeudActif.classList.remove("is-active")
          // Réinitialisation des styles du noeud précédent
          const oldCircle = noeudActif.querySelector('.orbital-node-circle')
          if (oldCircle) {
            oldCircle.style.backgroundColor = ""
            oldCircle.style.borderColor = ""
            oldCircle.style.color = ""
          }
        }

        noeud.classList.add("is-active")

        // Application de la couleur dynamique au cercle cliqué
        const circle = noeud.querySelector('.orbital-node-circle')
        if (circle) {
          circle.style.backgroundColor = noeud.dataset.color
          circle.style.borderColor = noeud.dataset.color
          circle.style.color = "#ffffff"
        }

        noeudActif = noeud
        enRotation = false
        ouvrirDetail(noeud)
      })
    })

    document.getElementById("detail-close").addEventListener("click", function () {
      detail.classList.remove("is-open")
      if (noeudActif) {
        noeudActif.classList.remove("is-active")
        // Réinitialisation des styles à la fermeture
        const oldCircle = noeudActif.querySelector('.orbital-node-circle')
        if (oldCircle) {
          oldCircle.style.backgroundColor = ""
          oldCircle.style.borderColor = ""
          oldCircle.style.color = ""
        }
        noeudActif = null
      }
      enRotation = true
    })

    placerNoeuds()
    animer()
  })
</script>
