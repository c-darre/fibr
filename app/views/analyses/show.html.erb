<%# ─────────────────────────────────────────────────────────────────────────
    Rafraîchissement automatique SANS JavaScript.
    Si l'analyse est en cours, on injecte une balise <meta> dans le <head>
    du layout (via content_for). Le navigateur recharge la page toutes les
    3 secondes. Quand l'analyse est terminée, la balise n'est plus injectée
    et la page reste stable.
    ───────────────────────────────────────────────────────────────────────── %>
<% if @analysis.pending? || @analysis.processing? %>
  <% content_for :head do %>
    <meta http-equiv="refresh" content="3">
  <% end %>
<% end %>

<div class="container py-5" style="max-width: 700px;">

  <%# turbo_frame_tag enveloppe la zone de résultats dans un conteneur Turbo.
      L'identifiant est dérivé du modèle (@analysis → "analysis_42").
      Lors du rechargement, Turbo met à jour uniquement ce bloc. %>
  <%= turbo_frame_tag @analysis do %>

    <% if @analysis.pending? || @analysis.processing? %>
      <%# ── Spinner : affiché tant que le job n'a pas terminé ──────── %>
      <div class="text-center py-5">
        <div class="spinner-border text-primary mb-4"
             role="status"
             style="width: 3rem; height: 3rem;">
          <span class="visually-hidden">Analyse en cours…</span>
        </div>
        <h3 class="mb-2">Analyse en cours</h3>
        <p class="text-muted">Nous analysons votre vêtement. Cela prend quelques secondes…</p>
      </div>

    <% elsif @analysis.completed? %>
      <%# ── Résultats : affichés une fois le job terminé ───────────── %>
      <h2 class="mb-4">Résultats de l'analyse</h2>

      <%# Calcul du score global en pourcentage (max 10 points par critère) %>
      <%
        total_score = @analysis.criteria.sum(:score)
        max_score   = @analysis.criteria.count * 10
        global_pct  = max_score > 0 ? (total_score.to_f / max_score * 100).round : 0
      %>

      <div class="card text-center p-4 mb-5 shadow-sm">
        <h5 class="text-muted mb-1">Score global</h5>
        <p class="display-2 fw-bold text-primary mb-2"><%= global_pct %>%</p>
        <div class="progress mx-auto" style="height: 12px; max-width: 300px;">
          <div class="progress-bar"
               role="progressbar"
               style="width: <%= global_pct %>%;"
               aria-valuenow="<%= global_pct %>"
               aria-valuemin="0"
               aria-valuemax="100"></div>
        </div>
      </div>

      <h5 class="mb-3">Détail par critère</h5>
      <div class="row g-3">
        <% @analysis.criteria.each do |criterion| %>
          <div class="col-md-4">
            <div class="card h-100 p-3 shadow-sm">
              <h6 class="fw-bold mb-1"><%= criterion.name %></h6>
              <p class="text-muted small flex-grow-1 mb-2"><%= criterion.detail %></p>
              <span class="badge bg-primary fs-6"><%= criterion.score %> / 10</span>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-5 text-center">
        <%= button_to "Nouvelle analyse", analyses_path,
              method: :post,
              class:  "btn btn-outline-primary" %>
      </div>

    <% elsif @analysis.failed? %>
      <%# ── Erreur : affichée si le job a levé une exception ────────── %>
      <div class="alert alert-danger">
        <h4 class="alert-heading">L'analyse a échoué</h4>
        <p class="mb-3">Une erreur est survenue lors du traitement. Veuillez réessayer.</p>
        <%= button_to "Réessayer", analyses_path,
              method: :post,
              class:  "btn btn-outline-danger" %>
      </div>
    <% end %>

  <% end %><%# fin turbo_frame_tag %>

</div>
