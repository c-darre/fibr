<div class="capture-page d-flex flex-column">

  <%= form_with model: [@analysis, @analysis.analysis_chat, Message], html: { multipart: true, class: "d-flex flex-column flex-grow-1 overflow-hidden" } do |f| %>

    <%# Inputs cachés caméra %>
    <%= f.file_field :photos, accept: "image/*", class: "d-none", id: "input-tag",   name: "message[photos][]" %>
    <%= f.file_field :photos, accept: "image/*", class: "d-none", id: "input-front", name: "message[photos][]" %>
    <%= f.file_field :photos, accept: "image/*", class: "d-none", id: "input-back",  name: "message[photos][]" %>

    <%# Inputs cachés upload galerie %>
    <%= f.file_field :photos, accept: "image/*", class: "d-none", id: "upload-tag",   name: "message[photos][]" %>
    <%= f.file_field :photos, accept: "image/*", class: "d-none", id: "upload-front", name: "message[photos][]" %>
    <%= f.file_field :photos, accept: "image/*", class: "d-none", id: "upload-back",  name: "message[photos][]" %>

    <canvas id="canvas" class="d-none"></canvas>

    <%# Zone caméra %>
    <div class="capture-camera position-relative flex-grow-1">
      <video id="camera-feed" autoplay playsinline muted
             class="position-absolute top-0 start-0 w-100 h-100"
             style="object-fit: cover;"></video>

      <%# Overlay flash : blanc, invisible par défaut, s'anime au clic %>
      <div id="flash-overlay"
           class="position-absolute top-0 start-0 w-100 h-100"
           style="background: white; opacity: 0; pointer-events: none; z-index: 999;"></div>

      <%# Bouton et texte flottent par-dessus la vidéo, en bas %>
      <div class="position-absolute bottom-0 w-100 text-center pb-4"
           style="background: linear-gradient(transparent, rgba(0,0,0,0.5));">

        <%# Bouton caméra + bouton flip + bouton flash côte à côte %>
        <div class="d-flex align-items-center justify-content-center gap-4 mb-3">

          <button type="button" id="btn-flip"
                  class="d-inline-flex align-items-center justify-content-center"
                  style="width: 44px; height: 44px; border-radius: 50%;
                         background: rgba(255,255,255,0.2);
                         border: 2px solid white;
                         cursor: pointer; color: white; font-size: 1.3rem;">
            ↺
          </button>

          <button type="button" id="btn-camera"
                  class="d-inline-flex align-items-center justify-content-center"
                  style="width: 72px; height: 72px; border-radius: 50%;
                         background: #f0ece4; border: 3px solid white;
                         box-shadow: 0 0 0 8px rgba(255,255,255,0.25); cursor: pointer;">
            <%# Icône caméra (par défaut) %>
            <svg id="icon-camera" xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="none" viewBox="0 0 24 24" stroke="#1A1A1A" stroke-width="1.5" style="pointer-events:none;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
            </svg>
            <%# Icône flèche (cachée tant que pas fini) %>
            <svg id="icon-arrow" class="d-none" xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="none" viewBox="0 0 24 24" stroke="#1A1A1A" stroke-width="2" style="pointer-events:none;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </button>

          <button type="button" id="btn-flash"
                  class="d-inline-flex align-items-center justify-content-center"
                  style="width: 44px; height: 44px; border-radius: 50%;
                         background: rgba(100,100,100,0.35); border: 2px solid rgba(150,150,150,0.6);
                         cursor: pointer;">
            <svg id="icon-flash" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="rgba(220,220,220,0.85)" stroke-width="2" style="pointer-events:none;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 2 3 14h9l-1 8 10-12h-9l1-8z" />
            </svg>
          </button>
        </div>

        <h2 id="scan-text" class="fw-bold mb-0" style="color:white; letter-spacing:1px; font-size:1.2rem;">SCAN YOUR TAG</h2>
      </div>
    </div>

    <%# Cartes étapes %>
    <div class="capture-list flex-shrink-0">

      <div class="capture-card is-active" id="card-tag">
        <div class="d-flex align-items-center">
          <span class="status-dot"></span>
          <span class="capture-label"><strong>Tag</strong><span>composition label</span></span>
        </div>
        <div class="d-flex align-items-center">
          <button type="button" class="capture-retake" id="retake-tag">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
          </button>
          <button type="button" class="capture-add" id="btn-upload-tag">+</button>
        </div>
      </div>

      <div class="capture-card is-pending" id="card-front">
        <div class="d-flex align-items-center">
          <span class="status-dot"></span>
          <span class="capture-label"><strong>Front</strong><span>of your product</span></span>
        </div>
        <div class="d-flex align-items-center">
          <button type="button" class="capture-retake" id="retake-front">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
          </button>
          <button type="button" class="capture-add" id="btn-upload-front">+</button>
        </div>
      </div>

      <div class="capture-card is-pending" id="card-back">
        <div class="d-flex align-items-center">
          <span class="status-dot"></span>
          <span class="capture-label"><strong>Back</strong><span>of your product</span></span>
        </div>
        <div class="d-flex align-items-center">
          <button type="button" class="capture-retake" id="retake-back">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
          </button>
          <button type="button" class="capture-add" id="btn-upload-back">+</button>
        </div>
      </div>

      <div class="pt-2">
        <%= f.submit "RESULTS →", id: "submit-btn", class: "btn_fibr_pill", disabled: true %>
      </div>
    </div>

  <% end %>
</div>

<script>
  let step = 1
  let facingMode = "environment" // "environment" = arrière, "user" = avant
  let flashActif = false         // Gestion globale de l'état du flash

  function demarrerCamera() {
    const video = document.getElementById("camera-feed")
    if (!video || video.srcObject) return
    navigator.mediaDevices.getUserMedia({ video: { facingMode: facingMode } })
      .then(function(stream) {
        video.srcObject = stream
        // Réappliquer le flash si l'utilisateur l'avait activé avant de switch de caméra
        appliquerFlashMateriel()
      })
      .catch(function(erreur) {
        document.getElementById("scan-text").textContent = "Error: " + erreur.message
      })
  }

  // -----------------------------------------------------------------
  // RETOURNER LA CAMÉRA
  // -----------------------------------------------------------------
  function retournerCamera() {
    const video = document.getElementById("camera-feed")
    if (!video.srcObject) return

    video.srcObject.getTracks().forEach(function(track) { track.stop() })
    video.srcObject = null

    facingMode = (facingMode === "environment") ? "user" : "environment"

    // On coupe proprement l'état du flash pour éviter les bugs sur la caméra avant
    flashActif = false
    majBoutonFlashUI()

    demarrerCamera()
  }

  document.addEventListener("DOMContentLoaded", demarrerCamera)
  document.addEventListener("turbo:load", demarrerCamera)

  // -----------------------------------------------------------------
  // ÉVÉNEMENTS ÉCOUTEURS
  // -----------------------------------------------------------------
  // Fusion : On utilise boutonPrincipal (logique design/étapes)
  // au lieu de capturerPhoto directement
  document.getElementById("btn-camera").addEventListener("click", boutonPrincipal)
  document.getElementById("btn-flip").addEventListener("click", retournerCamera)
  document.getElementById("btn-flash").addEventListener("click", basculerFlash)

  document.getElementById("btn-upload-tag").addEventListener("click",   function() { actionBouton("tag") })
  document.getElementById("btn-upload-front").addEventListener("click", function() { actionBouton("front") })
  document.getElementById("btn-upload-back").addEventListener("click",  function() { actionBouton("back") })

  document.getElementById("retake-tag").addEventListener("click",   function() { reprendrePhoto("tag") })
  document.getElementById("retake-front").addEventListener("click", function() { reprendrePhoto("front") })
  document.getElementById("retake-back").addEventListener("click",  function() { reprendrePhoto("back") })

  document.getElementById("upload-tag").addEventListener("change",   tagPris)
  document.getElementById("upload-front").addEventListener("change", devantPris)
  document.getElementById("upload-back").addEventListener("change",  derrierePris)

  // Bouton central : capture si étapes restantes, sinon soumet le formulaire
  function boutonPrincipal() {
    if (step >= 4) {
      document.getElementById("submit-btn").click()
    } else {
      capturerPhoto()
    }
  }

  // -----------------------------------------------------------------
  // GESTION DU FLASH (MATÉRIEL + VISUEL)
  // -----------------------------------------------------------------
  function basculerFlash() {
    flashActif = !flashActif
    majBoutonFlashUI()
    appliquerFlashMateriel()
  }

  function majBoutonFlashUI() {
    const btn  = document.getElementById("btn-flash")
    const icon = document.getElementById("icon-flash")
    if (flashActif) {
      btn.style.background  = "rgba(180,180,180,0.7)"
      btn.style.borderColor = "rgba(220,220,220,0.9)"
      icon.setAttribute("stroke", "white")
    } else {
      btn.style.background  = "rgba(100,100,100,0.35)"
      btn.style.borderColor = "rgba(150,150,150,0.6)"
      icon.setAttribute("stroke", "rgba(220,220,220,0.85)")
    }
  }

  function appliquerFlashMateriel() {
    const video = document.getElementById("camera-feed")
    if (video && video.srcObject) {
      const track = video.srcObject.getVideoTracks()[0]
      if (track && typeof track.getCapabilities === 'function') {
        const capabilities = track.getCapabilities()
        // Si le navigateur et le téléphone supportent la vraie LED (torch)
        if (capabilities.torch) {
          track.applyConstraints({
            advanced: [{ torch: flashActif }]
          }).catch(err => console.log("L'accès à la LED a échoué : ", err))
        }
      }
    }
  }

  function declencherFlashVisuel() {
    if (!flashActif) return

    const overlay = document.getElementById("flash-overlay")
    overlay.style.transition = "none"                      // allumage instantané
    overlay.style.opacity = "1"
    setTimeout(function() {
      overlay.style.transition = "opacity 0.15s ease-out" // fondu retour
      overlay.style.opacity = "0"
    }, 150)
  }

  // -----------------------------------------------------------------
  // CAPTURER UNE PHOTO DU FLUX VIDÉO
  // -----------------------------------------------------------------
  function capturerPhoto() {
    const video  = document.getElementById("camera-feed")
    const canvas = document.getElementById("canvas")

    canvas.width  = video.videoWidth
    canvas.height = video.videoHeight

    // Écran blanc synchrone (Ajout de la branche main)
    declencherFlashVisuel()

    // Prise instantanée du screen pendant le flash
    canvas.getContext("2d").drawImage(video, 0, 0)

    canvas.toBlob(function(blob) {
      const fichier = new File([blob], "photo.jpg", { type: "image/jpeg" })
      const transfert = new DataTransfer()
      transfert.items.add(fichier)

      // Logique d'attribution des étapes (Branche de refonte design)
      if (step === 1) {
        document.getElementById("input-tag").files = transfert.files
        tagPris()
      } else if (step === 2) {
        document.getElementById("input-front").files = transfert.files
        devantPris()
      } else if (step === 3) {
        document.getElementById("input-back").files = transfert.files
        derrierePris()
      }

      // Auto-extinction de la LED après la capture pour le confort de l'utilisateur
      if (flashActif) {
        basculerFlash()
      }
    })
  }

  // -----------------------------------------------------------------
  // MISE À JOUR DES STATUTS ET UI
  // -----------------------------------------------------------------
  function tagPris()      { finirEtape("card-tag") }
  function devantPris()   { finirEtape("card-front") }
  function derrierePris() { finirEtape("card-back") }

  function finirEtape(idCarte) {
    const carte = document.getElementById(idCarte)
    carte.classList.remove("is-active", "is-pending")
    carte.classList.add("is-done")
    carte.querySelector(".capture-add").innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5" style="pointer-events:none;"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
    majEtape()
  }

  // Si l'étape est faite → on reprend la photo. Sinon → galerie.
  function actionBouton(nom) {
    const carte = document.getElementById("card-" + nom)
    if (carte.classList.contains("is-done")) {
      reprendrePhoto(nom)
    } else if (carte.classList.contains("is-active")) {
      document.getElementById("upload-" + nom).click()
    }
  }

  // Réinitialise une étape : vide l'input, repasse la carte en "active"
  // Reprend UNIQUEMENT la photo cliquée, sans toucher aux autres
  function reprendrePhoto(nom) {
    document.getElementById("input-" + nom).value = ""
    document.getElementById("upload-" + nom).value = ""

    const carte = document.getElementById("card-" + nom)
    carte.classList.remove("is-done")
    carte.classList.add("is-active")
    carte.querySelector(".capture-add").textContent = "+"

    majEtape()
  }

  // Regarde quelles cartes sont faites et met à jour step + le bouton final
  function majEtape() {
    const ordre = ["tag", "front", "back"]

    step = 4
    for (let i = 0; i < ordre.length; i++) {
      const carte = document.getElementById("card-" + ordre[i])
      if (!carte.classList.contains("is-done")) {
        step = i + 1
        break
      }
    }

    ordre.forEach(function(n, i) {
      const carte = document.getElementById("card-" + n)
      if (carte.classList.contains("is-done")) return
      carte.classList.remove("is-active", "is-pending")
      carte.classList.add((i + 1 === step) ? "is-active" : "is-pending")
    })

    const tousFaits = (step === 4)
    document.getElementById("submit-btn").disabled = !tousFaits
    document.getElementById("icon-camera").classList.toggle("d-none", tousFaits)
    document.getElementById("icon-arrow").classList.toggle("d-none", !tousFaits)

    if (tousFaits) {
      document.getElementById("scan-text").textContent = "ALL DONE!"
    } else {
      document.getElementById("scan-text").textContent = "SCAN " + ordre[step - 1].toUpperCase() 
    }
  }

</script>
