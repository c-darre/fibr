<div class="container mt-4">
  <% if @analyses.empty? %>
    <p class="text-muted">You don't have a history yet!</p>
  <% else %>
    <%= form_with url: analyses_path, method: :get, local: true, class: "mb-4" do |f| %>
      <div class="input-group">
        <%# Rounded only on the start (left) side %>
        <%= f.text_field :query,
                        value: params[:query],
                        placeholder: "Search History...",
                        class: "form-control bg-white rounded-start-pill border-end-0" %>

        <%# Rounded only on the end (right) side %>
        <%= f.submit "Search",
                    class: "btn btn-primary rounded-end-pill" %>
      </div>
    <% end %>

    <ul class="list-unstyled p-0 m-0">
      <% @analyses.each do |analysis| %>
        <% photo = analysis.analysis_chat&.messages&.first&.photos&.second %>
        <li class="list-group-item d-flex justify-content-between align-items-center border rounded-4 bg-white mb-2 shadow-sm rounded">
          <div class="d-flex align-items-center gap-3">
            <% if photo %>
              <%= image_tag photo, class: "chat-thumbnail" %>
            <% else %>
              <div class="chat-thumbnail placeholder-emoji">👖</div>
            <% end %>

            <div>
              <h5 class="mb-1"><%= link_to analysis.garment_type.presence || "Analysis of #{analysis.created_at.strftime('%d/%m/%Y')}", analysis_path(analysis),
              class: "text-decoration-none text-dark fw-bold" %></h5>
              <small class="text-muted"><%= analysis.status %></small>
            </div>
          </div>

          <div class="m-2 text">
            <%# average across all criteria — same calculation as the show page %>
            <%
              total_score   = analysis.criteria.sum(:score)
              max_score     = analysis.criteria.count * 10
              average_score = max_score > 0 ? (total_score.to_f / max_score * 10).ceil(1) : nil
            %>

            <% if average_score %>
              <% if average_score < 4 %>
                <% couleur = "#dc3545" %> <%# Red %>
              <% elsif average_score < 7 %>
                <% couleur = "#ffc107" %> <%# Yellow %>
              <% else %>
                <% couleur = "#198754" %> <%# Green %>
              <% end %>

              <%
                score_percentage = (average_score * 10).to_i
                # UPDATED MATH FOR 60x60px RING: Radius 22, Circumference = 2 * PI * 22 = 138.23
                total_circumference = 138.23
                stroke_offset = total_circumference - ((score_percentage / 100.0) * total_circumference)
              %>

              <%# UPDATED: Added explicit relative layout to perfectly position the centered text block %>
              <div class="score-circle position-relative d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">

                <%# FIXED: Added transform: rotate(-90deg) and adjusted canvas window sizes to 60px %>
                <svg class="progress-ring" width="60" height="60" style="transform: rotate(-90deg); overflow: visible;">
                  <circle class="progress-ring-track" cx="30" cy="30" r="22" stroke="#e9ecef" stroke-width="2.5" fill="transparent" />

                  <circle class="progress-ring-fill"
                          cx="30"
                          cy="30"
                          r="22"
                          stroke="<%= couleur %>"
                          stroke-width="2.5"
                          fill="transparent"
                          stroke-dasharray="<%= total_circumference %>"
                          style="stroke-dashoffset: <%= stroke_offset %>px;" />
                </svg>

                <%# UPDATED: Positioned text firmly in the center layout and locked down font scale styling %>
                <div class="progress-inner-text position-absolute fw-bold text-dark" style="font-size: 14px; font-weight: 700 !important; line-height: 1; letter-spacing: -0.2px;">
                  <%= average_score %>
                </div>
              </div>

            <% else %>
              <%# UPDATED: Scaled the empty state frame box bounds to 60px to maintain consistent layout flow %>
              <div class="d-flex align-items-center justify-content-center text-muted me-2" style="width: 60px; height: 60px; font-size: 16px; font-weight: 700;">
                -
              </div>
            <% end %>
          </div>

        </li>
      <% end %>
    </ul>
  <% end %>
</div>
