<div class="container my-5">
  <div class="roclass="text-center h4 mb-4 fw-bold"w justify-content-center">
    <div class="col-md-6 col-lg-4">
      <h2 class="text-center h4 mb-4 fw-bold">Forgot your password?</h2>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= f.error_notification %>

        <div class="form-inputs">
          <%= f.input :email,
                      required: true,
                      autofocus: true,
                      input_html: { autocomplete: "email" } %>
        </div>

        <div class="form-actions d-grid gap-2 mt-4">
          <%= f.button :submit, "Send me password reset instructions" %>
        </div>
      <% end %>

      <div class="text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>

